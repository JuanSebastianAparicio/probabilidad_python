\section{Planteamiento del Problema}
 
\subsection{Contexto Ingenieril}
 
Un laboratorio de confiabilidad electrónica estudia el comportamiento de
\textbf{dos componentes} instalados en paralelo dentro de un sistema embebido.
Se registran dos variables continuas:
 
\begin{itemize}[leftmargin=1.5cm]
    \item $X$: tiempo de vida útil (en cientos de horas) del
          \emph{Componente A} (capacitor cerámico).
    \item $Y$: tiempo de vida útil (en cientos de horas) del
          \emph{Componente B} (resistencia de película delgada).
\end{itemize}
 
El sistema falla cuando \emph{ambos} componentes han fallado.
La empresa requiere calcular probabilidades de fallo conjunto y la vida
esperada de cada componente para optimizar sus planes de mantenimiento preventivo.
 
\subsection{Justificación del Modelo}
 
Con base en datos históricos de \num{500} sistemas en operación continua,
el equipo estadístico propone una densidad conjunta de la forma:
 
\begin{equation}
    f(x,y) = c\,x\,e^{-(x+2y)}, \qquad x > 0,\; y > 0
    \label{eq:densidad_raw}
\end{equation}
 
donde $c$ es una constante de normalización que se determinará en la
Sección~\ref{sec:modelo}.
Este modelo combina un factor lineal en $x$ (distribución Gamma de parámetros
$(2,1)$ en la marginal de $X$) con un decaimiento exponencial en $y$.
 
% ============================================================
%  2. MODELO MATEMÁTICO
% ============================================================
\section{Modelo Matemático}
\label{sec:modelo}
 
\subsection{Definición de las Variables Aleatorias}
 
\begin{definicion}[Vector aleatorio continuo]
Un par $(X,Y)$ es un \emph{vector aleatorio absolutamente continuo} si existe
una función $f:\mathbb{R}^2 \to [0,\infty)$ tal que para cualquier región
medible $A \subseteq \mathbb{R}^2$:
\[
    P\bigl((X,Y) \in A\bigr) = \iint_A f(x,y)\dx\dy
\]
La función $f$ recibe el nombre de \emph{función de densidad de probabilidad
conjunta} (f.d.p.c.).
\end{definicion}
 
Las variables del problema satisfacen:
\[
    X \in (0, +\infty), \qquad Y \in (0, +\infty)
\]
 
El \textbf{soporte} de la distribución es:
\begin{equation}
    \mathcal{S} = \{(x,y) \in \mathbb{R}^2 : x > 0,\; y > 0\}
    \label{eq:soporte}
\end{equation}
 
\subsection{Determinación de la Constante de Normalización}
 
Para que $f(x,y) = c\,x\,e^{-(x+2y)}$ sea una f.d.p. válida, se requiere:
\begin{equation}
    \int_0^{\infty}\int_0^{\infty} c\,x\,e^{-(x+2y)}\dx\dy = 1
    \label{eq:normalizacion}
\end{equation}
 
Separamos la integral doble gracias a la factorización del integrando:
\begin{align}
    \int_0^{\infty}\int_0^{\infty} c\,x\,e^{-x}e^{-2y}\dx\dy
        &= c\left(\int_0^{\infty} x\,e^{-x}\dx\right)
            \left(\int_0^{\infty} e^{-2y}\dy\right)
    \label{eq:factorizacion}
\end{align}
 
\textbf{Integral en } $x$: Usando la función Gamma $\Gamma(n) = (n-1)!$:
\begin{equation}
    \int_0^{\infty} x\,e^{-x}\dx = \Gamma(2) = 1! = 1
    \label{eq:int_x}
\end{equation}
 
\textbf{Integral en } $y$: Integral exponencial estándar:
\begin{equation}
    \int_0^{\infty} e^{-2y}\dy = \left[-\tfrac{1}{2}e^{-2y}\right]_0^{\infty}
    = 0 - \left(-\tfrac{1}{2}\right) = \frac{1}{2}
    \label{eq:int_y}
\end{equation}
 
Sustituyendo en \eqref{eq:normalizacion}:
\begin{equation}
    c \cdot 1 \cdot \frac{1}{2} = 1 \implies \boxed{c = 2}
    \label{eq:constante}
\end{equation}
 
\subsection{Función de Densidad Conjunta}
 
La f.d.p.c. queda completamente definida como:
\begin{equation}
    \boxed{f(x,y) = 2\,x\,e^{-(x+2y)}, \qquad x > 0,\; y > 0}
    \label{eq:densidad}
\end{equation}
y $f(x,y) = 0$ en cualquier otro punto.
 
