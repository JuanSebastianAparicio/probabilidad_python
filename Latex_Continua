%  3. DESARROLLO
% ============================================================
\section{Desarrollo}
 
\subsection{Verificación de la Integral Total}
 
Comprobamos que $\displaystyle\iint_{\mathcal{S}} f(x,y)\dx\dy = 1$:
 
\begin{align}
    \int_0^{\infty}\int_0^{\infty} 2xe^{-(x+2y)}\dx\dy
        &= 2\underbrace{\left(\int_0^{\infty}xe^{-x}\dx\right)}_{\Gamma(2)=1}
            \cdot\underbrace{\left(\int_0^{\infty}e^{-2y}\dy\right)}_{1/2} \notag \\
        &= 2 \cdot 1 \cdot \frac{1}{2} = \boxed{1} \quad \checkmark
    \label{eq:verif}
\end{align}
 
% --------------------------------------------------------
\subsection{Cálculo de Probabilidades en Regiones}
% --------------------------------------------------------
 
\subsubsection{Probabilidad \texorpdfstring{$P(X \leq 1,\; Y \leq 1)$}{P(X<=1, Y<=1)}}
 
\begin{align}
    P(X \leq 1,\; Y \leq 1)
        &= \int_0^1\int_0^1 2xe^{-(x+2y)}\dx\dy \notag \\
        &= 2\left(\int_0^1 xe^{-x}\dx\right)\left(\int_0^1 e^{-2y}\dy\right)
    \label{eq:p11}
\end{align}
 
\textbf{Integral en $x$} (integración por partes, $u=x$, $dv=e^{-x}dx$):
\begin{align}
    \int_0^1 xe^{-x}\dx
        &= \left[-xe^{-x}\right]_0^1 + \int_0^1 e^{-x}\dx \notag \\
        &= -e^{-1} + \left[-e^{-x}\right]_0^1 \notag \\
        &= -e^{-1} + (1 - e^{-1})
         = 1 - 2e^{-1}
    \label{eq:int_x_01}
\end{align}
 
\textbf{Integral en $y$}:
\begin{equation}
    \int_0^1 e^{-2y}\dy = \left[-\tfrac{1}{2}e^{-2y}\right]_0^1
    = \frac{1}{2}(1 - e^{-2})
    \label{eq:int_y_01}
\end{equation}
 
Por tanto:
\begin{align}
    P(X \leq 1,\; Y \leq 1)
        &= 2\left(1 - 2e^{-1}\right)\cdot\frac{1}{2}\left(1 - e^{-2}\right) \notag \\
        &= \left(1 - \frac{2}{e}\right)\!\left(1 - \frac{1}{e^2}\right)
    \label{eq:p11_exacta}
\end{align}
 
\begin{resultado}
\[
P(X \leq 1,\; Y \leq 1)
= \left(1 - \frac{2}{e}\right)\!\left(1 - \frac{1}{e^2}\right)
\approx \mathbf{0.2285}
\]
\end{resultado}
 
\subsubsection{Probabilidad \texorpdfstring{$P(X + Y \leq 2)$}{P(X+Y<=2)}}
 
Para $X + Y \leq 2$ con $x > 0$, $y > 0$, la región de integración es:
$\mathcal{R} = \{(x,y): 0 < x,\; 0 < y,\; x+y \leq 2\}$.
 
\[
    P(X+Y \leq 2) = \int_0^2\int_0^{2-x} 2xe^{-(x+2y)}\dy\dx
\]
 
\textbf{Integral interior en $y$}:
\begin{align}
    \int_0^{2-x} 2xe^{-x}e^{-2y}\dy
        &= 2xe^{-x}\left[-\frac{1}{2}e^{-2y}\right]_0^{2-x} \notag \\
        &= xe^{-x}\!\left(1 - e^{-2(2-x)}\right)
         = xe^{-x} - xe^{-x}e^{-(4-2x)} \notag \\
        &= xe^{-x} - xe^{-(4-x)}
    \label{eq:int_y_suma}
\end{align}
 
\textbf{Integral exterior en $x$}:
\begin{align}
    P(X+Y \leq 2)
        &= \int_0^2 \!\left(xe^{-x} - xe^{-(4-x)}\right)\dx \notag \\
        &= \int_0^2 xe^{-x}\dx - e^{-4}\int_0^2 xe^{x}\dx
    \label{eq:p_suma}
\end{align}
 
\textbf{Primera integral} (por partes):
\begin{equation}
    \int_0^2 xe^{-x}\dx = 1 - 3e^{-2}
    \label{eq:I1}
\end{equation}
 
\textbf{Segunda integral} (por partes, $u=x$, $dv=e^x dx$):
\begin{align}
    \int_0^2 xe^{x}\dx
        &= \left[xe^x - e^x\right]_0^2
         = (2e^2 - e^2) - (0 - 1)
         = e^2 + 1
    \label{eq:I2}
\end{align}
 
Combinando:
\begin{align}
    P(X+Y \leq 2)
        &= \left(1 - 3e^{-2}\right) - e^{-4}\left(e^2 + 1\right) \notag \\
        &= 1 - 3e^{-2} - e^{-2} - e^{-4} \notag \\
        &= 1 - 4e^{-2} - e^{-4}
    \label{eq:p_suma_exacta}
\end{align}
 
\begin{resultado}
\[
P(X+Y \leq 2)
= 1 - 4e^{-2} - e^{-4}
\approx \mathbf{0.4403}
\]
\end{resultado}
 
\subsubsection{Probabilidad \texorpdfstring{$P(Y > X)$}{P(Y>X)}}
 
La región es $\{(x,y): x>0,\;y>x\}$.
 
\begin{align}
    P(Y > X)
        &= \int_0^{\infty}\int_x^{\infty} 2xe^{-(x+2y)}\dy\dx \notag \\
        &= \int_0^{\infty} 2xe^{-x}\left[-\tfrac{1}{2}e^{-2y}\right]_x^{\infty}\dx \notag \\
        &= \int_0^{\infty} xe^{-x} \cdot e^{-2x}\dx
         = \int_0^{\infty} xe^{-3x}\dx
    \label{eq:p_yx}
\end{align}
 
Usando $\displaystyle\int_0^\infty x e^{-\lambda x}\dx = \frac{1}{\lambda^2}$:
\begin{equation}
    P(Y > X) = \frac{1}{3^2} = \boxed{\frac{1}{9} \approx 0.1111}
    \label{eq:p_yx_exacta}
\end{equation}
 
% --------------------------------------------------------
\subsection{Distribuciones Marginales}
% --------------------------------------------------------
 
\subsubsection{Marginal de \texorpdfstring{$X$}{X}}
 
\begin{equation}
    f_X(x) = \int_{-\infty}^{\infty} f(x,y)\dy
    = \int_0^{\infty} 2xe^{-x}e^{-2y}\dy, \qquad x > 0
\end{equation}
 
\begin{align}
    f_X(x)
        &= 2xe^{-x}\int_0^{\infty}e^{-2y}\dy
         = 2xe^{-x} \cdot \frac{1}{2}
         = \boxed{xe^{-x}}, \qquad x > 0
    \label{eq:margX}
\end{align}
 
Se reconoce la distribución \textbf{Gamma}$(\alpha=2,\,\lambda=1)$.
 
\subsubsection{Marginal de \texorpdfstring{$Y$}{Y}}
 
\begin{equation}
    f_Y(y) = \int_0^{\infty} 2xe^{-x}e^{-2y}\dx
    = 2e^{-2y}\int_0^{\infty}xe^{-x}\dx, \qquad y > 0
\end{equation}
 
\begin{align}
    f_Y(y)
        &= 2e^{-2y} \cdot \Gamma(2)
         = 2e^{-2y} \cdot 1
         = \boxed{2e^{-2y}}, \qquad y > 0
    \label{eq:margY}
\end{align}
 
Se reconoce la distribución \textbf{Exponencial}$(\lambda=2)$.
 
% --------------------------------------------------------
\subsection{Esperanza Matemática}
% --------------------------------------------------------
 
\subsubsection{Esperanza de \texorpdfstring{$X$}{X}}
 
Con $f_X(x) = xe^{-x}$ (Gamma$(2,1)$):
\begin{align}
    E(X) &= \int_0^{\infty} x \cdot xe^{-x}\dx
           = \int_0^{\infty} x^2 e^{-x}\dx
           = \Gamma(3) = 2! = \boxed{2}
    \label{eq:EX}
\end{align}
 
\subsubsection{Esperanza de \texorpdfstring{$Y$}{Y}}
 
Con $f_Y(y) = 2e^{-2y}$ (Exponencial$(\lambda=2)$):
\begin{align}
    E(Y) &= \int_0^{\infty} y \cdot 2e^{-2y}\dy
           = 2\int_0^{\infty} ye^{-2y}\dy
           = 2 \cdot \frac{1}{2^2}
           = \boxed{\frac{1}{2}}
    \label{eq:EY}
\end{align}
 
\subsubsection{Esperanza de \texorpdfstring{$XY$}{XY}}
 
\begin{align}
    E(XY) &= \int_0^{\infty}\int_0^{\infty} xy \cdot 2xe^{-(x+2y)}\dx\dy \notag \\
           &= 2\left(\int_0^{\infty}x^2 e^{-x}\dx\right)
               \left(\int_0^{\infty}ye^{-2y}\dy\right) \notag \\
           &= 2 \cdot \Gamma(3) \cdot \frac{1}{4}
            = 2 \cdot 2 \cdot \frac{1}{4}
            = \boxed{1}
    \label{eq:EXY}
\end{align}
 
% --------------------------------------------------------
\subsection{Varianza y Covarianza}
% --------------------------------------------------------
 
\subsubsection{Varianza de \texorpdfstring{$X$}{X}}
 
Para Gamma$(\alpha, \lambda)$: $\mathrm{Var}(X) = \alpha/\lambda^2$.
Con $\alpha=2$, $\lambda=1$:
\begin{equation}
    E(X^2) = \Gamma(4) = 3! = 6
    \qquad\Rightarrow\qquad
    \mathrm{Var}(X) = 6 - 2^2 = \boxed{2}
    \label{eq:VarX}
\end{equation}
 
\subsubsection{Varianza de \texorpdfstring{$Y$}{Y}}
 
Para Exponencial$(\lambda=2)$: $\mathrm{Var}(Y) = 1/\lambda^2$.
\begin{equation}
    E(Y^2) = 2\int_0^{\infty}y^2 e^{-2y}\dy = 2\cdot\frac{\Gamma(3)}{2^3} = \frac{1}{2}
    \qquad\Rightarrow\qquad
    \mathrm{Var}(Y) = \frac{1}{2} - \frac{1}{4} = \boxed{\frac{1}{4}}
    \label{eq:VarY}
\end{equation}
 
\subsubsection{Covarianza}
 
\begin{equation}
    \mathrm{Cov}(X,Y) = E(XY) - E(X)\,E(Y) = 1 - 2 \cdot \frac{1}{2} = \boxed{0}
    \label{eq:Cov}
\end{equation}
 
% --------------------------------------------------------
\subsection{Verificación de Independencia}
% --------------------------------------------------------
 
\begin{proposicion}
$X$ e $Y$ son independientes $\iff$ $f(x,y) = f_X(x)\cdot f_Y(y)$ c.t.p.
\end{proposicion}
 
Verificamos directamente:
\begin{align}
    f_X(x)\cdot f_Y(y)
        &= \left(xe^{-x}\right)\cdot\left(2e^{-2y}\right)
         = 2xe^{-(x+2y)}
         = f(x,y) \quad \checkmark
    \label{eq:independencia}
\end{align}
 
\begin{resultado}
\[
    \boxed{X \text{ e } Y \textbf{ son independientes.}}
\]
La factorización exacta $f(x,y) = f_X(x)\cdot f_Y(y)$ se cumple en todo $\mathcal{S}$,
y $\mathrm{Cov}(X,Y) = 0$ es consistente con dicha independencia.
\end{resultado}
 
