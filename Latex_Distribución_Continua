\section{Parte III: Análisis Conjunto de $X$ e $Y$}

\subsection{Distribución Conjunta}

Dado que $X$ e $Y$ son \textbf{independientes}, la densidad conjunta es:
\begin{equation}
    f(x,y) = f_X(x)\cdot f_Y(y)
    = \frac{1}{10\sqrt{2\pi}}\,e^{-(x-70)^2/200}
      \cdot \frac{1}{5}\,e^{-y/5},
    \qquad x \in \mathbb{R},\; y > 0
    \label{eq:conjunta}
\end{equation}

\subsection{Probabilidades Conjuntas}

Por independencia, las probabilidades conjuntas se factorizan:
\begin{equation}
    P(A \cap B) = P(A)\cdot P(B)
    \label{eq:factorizacion}
\end{equation}

\subsubsection{\texorpdfstring{$P(X \geq 60 \text{ y } Y < 3)$}{P(X>=60 y Y<3)}: aprobar Y espera corta}

\begin{align}
    P(X \geq 60,\; Y < 3)
        &= P(X \geq 60)\cdot P(Y < 3) \notag \\
        &= \Phi(1)\cdot(1-e^{-0.6}) \notag \\
        &\approx 0.8413 \times 0.4512
         = \mathbf{0.3796}
    \label{eq:conj1}
\end{align}

\subsubsection{\texorpdfstring{$P(X \geq 85 \text{ y } Y > 10)$}{P(X>=85 y Y>10)}: sobresaliente Y larga espera}

\begin{align}
    P(X \geq 85,\; Y > 10)
        &= P(X \geq 85)\cdot P(Y > 10) \notag \\
        &= (1-\Phi(1.5))\cdot e^{-2} \notag \\
        &\approx 0.0668 \times 0.1353
         = \mathbf{0.0090}
    \label{eq:conj2}
\end{align}

\subsection{Esperanza y Varianza Conjuntas}

\begin{align}
    E(X + Y) &= E(X) + E(Y) = 70 + 5 = \mathbf{75} \\[4pt]
    \mathrm{Var}(X+Y) &= \mathrm{Var}(X) + \mathrm{Var}(Y) \quad
        \text{(por independencia)} \notag \\
        &= 100 + 25 = \mathbf{125} \\[4pt]
    E(XY) &= E(X)\cdot E(Y) = 70 \times 5 = \mathbf{350}
        \quad \text{(por independencia)} \\[4pt]
    \mathrm{Cov}(X,Y) &= E(XY) - E(X)E(Y) = 350 - 350 = \mathbf{0}
\end{align}

