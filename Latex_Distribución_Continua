\section{Parte I: Distribución Normal}

% --------------------------------------------------------
\subsection{Definición y Función de Densidad}
% --------------------------------------------------------

\begin{defbox}[Distribución Normal]
Se dice que $X \sim \mathcal{N}(\mu, \sigma^2)$ si su función de densidad
de probabilidad (f.d.p.) es:
\begin{equation}
    f_X(x) = \frac{1}{\sigma\sqrt{2\pi}}\,
              \exp\!\left(-\frac{(x-\mu)^2}{2\sigma^2}\right),
    \qquad x \in \mathbb{R}
    \label{eq:normal_pdf}
\end{equation}
con parámetros $\mu \in \mathbb{R}$ (media) y $\sigma^2 > 0$ (varianza).
\end{defbox}

\textbf{Parámetros del problema:}
\[
    X \sim \mathcal{N}(\mu = 70,\; \sigma^2 = 100)
    \qquad (\sigma = 10)
\]

La densidad queda:
\begin{equation}
    f_X(x) = \frac{1}{10\sqrt{2\pi}}\,
              \exp\!\left(-\frac{(x-70)^2}{200}\right),
    \qquad x \in \mathbb{R}
    \label{eq:normal_problema}
\end{equation}

% --------------------------------------------------------
\subsection{Momentos de la Distribución Normal}
% --------------------------------------------------------

\begin{propbox}[Momentos de $X \sim \mathcal{N}(\mu,\sigma^2)$]
\begin{align}
    E(X)      &= \mu                     \label{eq:EX_normal} \\[4pt]
    E(X^2)    &= \mu^2 + \sigma^2        \label{eq:EX2_normal} \\[4pt]
    \mathrm{Var}(X) &= \sigma^2          \label{eq:VarX_normal} \\[4pt]
    \mathrm{DE}(X)  &= \sigma            \label{eq:DE_normal}
\end{align}
\end{propbox}

Aplicando al problema:
\begin{align}
    E(X)            &= 70      \label{eq:EX_val} \\
    \mathrm{Var}(X) &= 100     \label{eq:VarX_val} \\
    \mathrm{DE}(X)  &= 10      \label{eq:DE_val}
\end{align}

\textbf{Interpretación:} La calificación promedio es de 70 puntos, con una
desviación estándar de 10 puntos.

% --------------------------------------------------------
\subsection{Estandarización y Variable $Z$}
% --------------------------------------------------------

Toda variable $X \sim \mathcal{N}(\mu,\sigma^2)$ se transforma a la
\emph{normal estándar} $Z \sim \mathcal{N}(0,1)$ mediante:
\begin{equation}
    Z = \frac{X - \mu}{\sigma} = \frac{X - 70}{10}
    \label{eq:estandarizacion}
\end{equation}

La f.d.p. de $Z$ es:
\begin{equation}
    \varphi(z) = \frac{1}{\sqrt{2\pi}}\,e^{-z^2/2},
    \qquad z \in \mathbb{R}
    \label{eq:normal_std}
\end{equation}

% --------------------------------------------------------
\subsection{Cálculo de Probabilidades}
% --------------------------------------------------------

Sea $\Phi(z) = P(Z \leq z)$ la función de distribución acumulada (CDF)
de la normal estándar.

\subsubsection{Probabilidad de aprobar: \texorpdfstring{$P(X \geq 60)$}{P(X>=60)}}

\begin{align}
    P(X \geq 60)
        &= P\!\left(\frac{X-70}{10} \geq \frac{60-70}{10}\right)
         = P(Z \geq -1) \notag \\
        &= 1 - \Phi(-1)
         = \Phi(1)
    \label{eq:p_aprobar}
\end{align}

\begin{resbox}
\[
    P(X \geq 60) = \Phi(1) \approx \mathbf{0.8413}
\]
El $84.13\%$ de los estudiantes obtiene una calificación de 60 o más.
\end{resbox}

\subsubsection{Probabilidad de calificación sobresaliente: \texorpdfstring{$P(X \geq 85)$}{P(X>=85)}}

\begin{align}
    P(X \geq 85)
        &= P\!\left(Z \geq \frac{85-70}{10}\right)
         = P(Z \geq 1.5) \notag \\
        &= 1 - \Phi(1.5)
    \label{eq:p_sobresaliente}
\end{align}

\begin{resbox}
\[
    P(X \geq 85) = 1 - \Phi(1.5) \approx \mathbf{0.0668}
\]
Solo el $6.68\%$ de los estudiantes obtiene 85 o más puntos.
\end{resbox}

\subsubsection{Probabilidad en un intervalo: \texorpdfstring{$P(60 \leq X \leq 80)$}{P(60<=X<=80)}}

\begin{align}
    P(60 \leq X \leq 80)
        &= P\!\left(\frac{60-70}{10} \leq Z \leq \frac{80-70}{10}\right)
         = P(-1 \leq Z \leq 1) \notag \\
        &= \Phi(1) - \Phi(-1)
         = 2\Phi(1) - 1
    \label{eq:p_intervalo}
\end{align}

\begin{resbox}
\[
    P(60 \leq X \leq 80) = 2\Phi(1) - 1 \approx \mathbf{0.6827}
\]
La regla empírica $\mu \pm \sigma$: el $68.27\%$ de los estudiantes
obtiene entre 60 y 80 puntos.
\end{resbox}

\subsubsection{Regla empírica \texorpdfstring{$\mu \pm 2\sigma$}{mu±2sigma}}

\begin{align}
    P(50 \leq X \leq 90)
        &= P(-2 \leq Z \leq 2)
         = 2\Phi(2) - 1
         \approx \mathbf{0.9545}
    \label{eq:p_2sigma}
\end{align}

\subsubsection{Cuantil: Percentil 90}

Se busca $x_{0.90}$ tal que $P(X \leq x_{0.90}) = 0.90$:
\begin{align}
    \Phi(z_{0.90}) = 0.90
        &\implies z_{0.90} \approx 1.2816 \notag \\
        &\implies x_{0.90} = \mu + z_{0.90}\cdot\sigma
                           = 70 + 1.2816 \times 10
    \label{eq:percentil90}
\end{align}

\begin{resbox}
\[
    x_{0.90} \approx \mathbf{82.82}
\]
El $90\%$ de los estudiantes obtiene menos de $82.82$ puntos.
\end{resbox}

% --------------------------------------------------------
\subsection{Verificación de la Integral Total}
% --------------------------------------------------------

\begin{equation}
    \int_{-\infty}^{\infty} f_X(x)\dx
    = \int_{-\infty}^{\infty}
        \frac{1}{\sigma\sqrt{2\pi}} e^{-(x-\mu)^2/(2\sigma^2)}\dx
    \overset{z=(x-\mu)/\sigma}{=}
    \frac{1}{\sqrt{2\pi}}\int_{-\infty}^{\infty} e^{-z^2/2}\,dz
    = 1 \quad \checkmark
    \label{eq:normalizacion_normal}
\end{equation}

donde se usa la identidad de Gauss $\displaystyle\int_{-\infty}^{\infty}e^{-z^2/2}dz = \sqrt{2\pi}$.

