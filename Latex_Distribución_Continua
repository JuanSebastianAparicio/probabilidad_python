\section{Parte II: Distribución Exponencial}

% --------------------------------------------------------
\subsection{Definición y Función de Densidad}
% --------------------------------------------------------

\begin{defbox}[Distribución Exponencial]
Se dice que $Y \sim \mathrm{Exp}(\lambda)$ si su f.d.p. es:
\begin{equation}
    f_Y(y) = \lambda\,e^{-\lambda y},
    \qquad y > 0,\quad \lambda > 0
    \label{eq:exp_pdf}
\end{equation}
con parámetro de tasa $\lambda > 0$.
\end{defbox}

\textbf{Parámetros del problema:} La ventanilla atiende en promedio a
$\lambda = 1/5$ estudiantes por minuto (uno cada 5 minutos):
\[
    Y \sim \mathrm{Exp}\!\left(\lambda = \tfrac{1}{5}\right)
\]

La densidad queda:
\begin{equation}
    f_Y(y) = \frac{1}{5}\,e^{-y/5},
    \qquad y > 0
    \label{eq:exp_problema}
\end{equation}

% --------------------------------------------------------
\subsection{Momentos de la Distribución Exponencial}
% --------------------------------------------------------

\begin{propbox}[Momentos de $Y \sim \mathrm{Exp}(\lambda)$]
\begin{align}
    E(Y)            &= \frac{1}{\lambda}            \label{eq:EY_exp} \\[4pt]
    E(Y^2)          &= \frac{2}{\lambda^2}          \label{eq:EY2_exp} \\[4pt]
    \mathrm{Var}(Y) &= \frac{1}{\lambda^2}          \label{eq:VarY_exp} \\[4pt]
    \mathrm{DE}(Y)  &= \frac{1}{\lambda}            \label{eq:DE_exp}
\end{align}
\end{propbox}

\textbf{Derivación de $E(Y)$:}
\begin{align}
    E(Y) &= \int_0^{\infty} y \cdot \frac{1}{5} e^{-y/5}\dy \notag \\
         &= \frac{1}{5}\left[-5ye^{-y/5}\right]_0^{\infty}
            + \frac{1}{5}\int_0^{\infty}5e^{-y/5}\dy \notag \\
         &= 0 + \int_0^{\infty}e^{-y/5}\dy
          = \left[-5e^{-y/5}\right]_0^{\infty} = 5
    \label{eq:EY_deriv}
\end{align}

Aplicando al problema ($\lambda = 1/5$):
\begin{align}
    E(Y)            &= 5 \text{ minutos}   \\
    \mathrm{Var}(Y) &= 25 \text{ min}^2    \\
    \mathrm{DE}(Y)  &= 5 \text{ minutos}
\end{align}

% --------------------------------------------------------
\subsection{Función de Distribución Acumulada}
% --------------------------------------------------------

\begin{equation}
    F_Y(y) = P(Y \leq y) = \int_0^y \frac{1}{5}e^{-t/5}\,dt
           = 1 - e^{-y/5}, \qquad y > 0
    \label{eq:exp_cdf}
\end{equation}

% --------------------------------------------------------
\subsection{Propiedad de Carencia de Memoria}
% --------------------------------------------------------

\begin{propbox}[Sin memoria]
La distribución Exponencial es la única distribución continua con la
propiedad de \emph{carencia de memoria}:
\begin{equation}
    P(Y > s + t \mid Y > s) = P(Y > t), \qquad \forall\, s, t > 0
    \label{eq:sin_memoria}
\end{equation}
\end{propbox}

\textbf{Demostración:}
\begin{align}
    P(Y > s + t \mid Y > s)
        &= \frac{P(Y > s+t)}{P(Y > s)}
         = \frac{e^{-(s+t)/5}}{e^{-s/5}}
         = e^{-t/5}
         = P(Y > t) \quad \checkmark
    \label{eq:sin_memoria_dem}
\end{align}

% --------------------------------------------------------
\subsection{Cálculo de Probabilidades}
% --------------------------------------------------------

\subsubsection{Probabilidad de esperar menos de 3 minutos: \texorpdfstring{$P(Y < 3)$}{P(Y<3)}}

\begin{align}
    P(Y < 3) &= F_Y(3) = 1 - e^{-3/5} = 1 - e^{-0.6}
    \label{eq:p_y3}
\end{align}

\begin{resbox}
\[
    P(Y < 3) = 1 - e^{-0.6} \approx \mathbf{0.4512}
\]
El $45.12\%$ de los estudiantes espera menos de 3 minutos.
\end{resbox}

\subsubsection{Probabilidad de esperar más de 10 minutos: \texorpdfstring{$P(Y > 10)$}{P(Y>10)}}

\begin{align}
    P(Y > 10) &= 1 - F_Y(10) = e^{-10/5} = e^{-2}
    \label{eq:p_y10}
\end{align}

\begin{resbox}
\[
    P(Y > 10) = e^{-2} \approx \mathbf{0.1353}
\]
El $13.53\%$ de los estudiantes espera más de 10 minutos.
\end{resbox}

\subsubsection{Probabilidad en un intervalo: \texorpdfstring{$P(2 \leq Y \leq 8)$}{P(2<=Y<=8)}}

\begin{align}
    P(2 \leq Y \leq 8)
        &= F_Y(8) - F_Y(2)
         = \left(1 - e^{-8/5}\right) - \left(1 - e^{-2/5}\right) \notag \\
        &= e^{-0.4} - e^{-1.6}
    \label{eq:p_y_intervalo}
\end{align}

\begin{resbox}
\[
    P(2 \leq Y \leq 8) = e^{-0.4} - e^{-1.6} \approx \mathbf{0.4684}
\]
\end{resbox}

\subsubsection{Mediana de la distribución}

Se busca $m$ tal que $F_Y(m) = 0.5$:
\begin{align}
    1 - e^{-m/5} = 0.5
        &\implies e^{-m/5} = 0.5
         \implies m = 5\ln 2
    \label{eq:mediana_exp}
\end{align}

\begin{resbox}
\[
    m = 5\ln 2 \approx \mathbf{3.466} \text{ minutos}
\]
La mediana es menor que la media ($E(Y)=5$), confirmando la asimetría
positiva de la distribución Exponencial.
\end{resbox}

\subsubsection{Verificación de la integral total}

\begin{equation}
    \int_0^{\infty} \frac{1}{5}e^{-y/5}\dy
    = \frac{1}{5}\left[-5e^{-y/5}\right]_0^{\infty}
    = \frac{1}{5}(0+5) = 1 \quad \checkmark
    \label{eq:normalizacion_exp}
\end{equation}

