% --------------------------------------------------------
\subsection{Esperanza Matemática}
% --------------------------------------------------------
 
\subsubsection{Esperanza de \texorpdfstring{$X$}{X}}
 
\begin{equation}
    E(X) = \sum_{x=0}^{2} x \cdot f_X(x)
\end{equation}
 
\begin{align}
    E(X) &= 0 \cdot 0.35 + 1 \cdot 0.40 + 2 \cdot 0.25 \notag \\
         &= 0 + 0.40 + 0.50
          = \boxed{0.90}
    \label{eq:EX}
\end{align}
 
\subsubsection{Esperanza de \texorpdfstring{$Y$}{Y}}
 
\begin{equation}
    E(Y) = \sum_{y=0}^{2} y \cdot f_Y(y)
\end{equation}
 
\begin{align}
    E(Y) &= 0 \cdot 0.40 + 1 \cdot 0.40 + 2 \cdot 0.20 \notag \\
         &= 0 + 0.40 + 0.40
          = \boxed{0.80}
    \label{eq:EY}
\end{align}
 
\subsubsection{Esperanza de \texorpdfstring{$X+Y$}{X+Y} y \texorpdfstring{$XY$}{XY}}
 
Por linealidad de la esperanza:
\begin{equation}
    E(X+Y) = E(X) + E(Y) = 0.90 + 0.80 = \boxed{1.70}
\end{equation}
 
La esperanza del producto se calcula directamente:
\begin{align}
    E(XY) &= \sum_{x,y} xy \cdot f(x,y) \notag \\
           &= (0)(0)(0.20)+(0)(1)(0.10)+(0)(2)(0.05) \notag \\
           &\quad +(1)(0)(0.15)+(1)(1)(0.20)+(1)(2)(0.05) \notag \\
           &\quad +(2)(0)(0.05)+(2)(1)(0.10)+(2)(2)(0.10) \notag \\
           &= 0+0+0+0+0.20+0.10+0+0.20+0.40 \notag \\
           &= \boxed{0.90}
    \label{eq:EXY}
\end{align}
 
% --------------------------------------------------------
\subsection{Varianza y Covarianza}
% --------------------------------------------------------
 
\subsubsection{Varianza de \texorpdfstring{$X$}{X}}
 
\begin{equation}
    \mathrm{Var}(X) = E(X^2) - [E(X)]^2
\end{equation}
 
\begin{align}
    E(X^2) &= 0^2(0.35) + 1^2(0.40) + 2^2(0.25)
            = 0 + 0.40 + 1.00 = 1.40 \\[4pt]
    \mathrm{Var}(X) &= 1.40 - (0.90)^2
                     = 1.40 - 0.81
                     = \boxed{0.59}
    \label{eq:VarX}
\end{align}
 
\subsubsection{Varianza de \texorpdfstring{$Y$}{Y}}
 
\begin{align}
    E(Y^2) &= 0^2(0.40) + 1^2(0.40) + 2^2(0.20)
            = 0 + 0.40 + 0.80 = 1.20 \\[4pt]
    \mathrm{Var}(Y) &= 1.20 - (0.80)^2
                     = 1.20 - 0.64
                     = \boxed{0.56}
    \label{eq:VarY}
\end{align}
 
\subsubsection{Covarianza}
 
\begin{equation}
    \mathrm{Cov}(X,Y) = E(XY) - E(X)\,E(Y)
\end{equation}
 
\begin{align}
    \mathrm{Cov}(X,Y) &= 0.90 - (0.90)(0.80)
                       = 0.90 - 0.72
                       = \boxed{0.18}
    \label{eq:Cov}
\end{align}
 
\subsubsection{Coeficiente de Correlación de Pearson}
 
\begin{equation}
    \rho_{XY} = \frac{\mathrm{Cov}(X,Y)}{\sqrt{\mathrm{Var}(X)\cdot\mathrm{Var}(Y)}}
\end{equation}
 
\begin{align}
    \rho_{XY} &= \frac{0.18}{\sqrt{0.59 \times 0.56}}
               = \frac{0.18}{\sqrt{0.3304}}
               = \frac{0.18}{0.5748}
               \approx \boxed{0.313}
    \label{eq:corr}
\end{align}
 
% --------------------------------------------------------
\subsection{Verificación de Independencia}
% --------------------------------------------------------
 
\begin{proposicion}
Las variables aleatorias $X$ e $Y$ son \textbf{independientes} si y sólo si:
\begin{equation}
    f(x,y) = f_X(x)\cdot f_Y(y) \qquad \forall\,(x,y) \in \mathcal{S}
    \label{eq:indep}
\end{equation}
\end{proposicion}
 
Verificamos para cada celda de la tabla:
 
\begin{table}[ht]
    \centering
    \caption{Comparación: $f(x,y)$ vs.\;$f_X(x)\cdot f_Y(y)$}
    \renewcommand{\arraystretch}{1.4}
    \begin{tabular}{cc|c|c|c}
        \toprule
        \rowcolor{azulClaro}
        $x$ & $y$ & $f(x,y)$ & $f_X(x)\cdot f_Y(y)$ & ¿Iguales? \\
        \midrule
        0 & 0 & 0.20 & $0.35 \times 0.40 = 0.140$ & \textcolor{red}{No} \\
        0 & 1 & 0.10 & $0.35 \times 0.40 = 0.140$ & \textcolor{red}{No} \\
        0 & 2 & 0.05 & $0.35 \times 0.20 = 0.070$ & \textcolor{red}{No} \\
        1 & 0 & 0.15 & $0.40 \times 0.40 = 0.160$ & \textcolor{red}{No} \\
        1 & 1 & 0.20 & $0.40 \times 0.40 = 0.160$ & \textcolor{red}{No} \\
        1 & 2 & 0.05 & $0.40 \times 0.20 = 0.080$ & \textcolor{red}{No} \\
        2 & 0 & 0.05 & $0.25 \times 0.40 = 0.100$ & \textcolor{red}{No} \\
        2 & 1 & 0.10 & $0.25 \times 0.40 = 0.100$ & \textcolor{red}{No} \\
        2 & 2 & 0.10 & $0.25 \times 0.20 = 0.050$ & \textcolor{green!60!black}{Sí} \\
        \bottomrule
    \end{tabular}
    \label{tab:independencia}
\end{table}
 
Como la condición \eqref{eq:indep} \textbf{no se cumple} en la mayoría de las celdas,
concluimos que:
 
\begin{equation}
    \boxed{X \text{ e } Y \textbf{ NO son independientes.}}
\end{equation}
 
Esto es consistente con $\mathrm{Cov}(X,Y) = 0.18 \neq 0$.
 
