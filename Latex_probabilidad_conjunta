\section{Modelo Matemático}
 
\subsection{Definición de las Variables Aleatorias}
 
\begin{definicion}[Variable aleatoria discreta bivariada]
Sea $(\Omega, \mathcal{F}, P)$ un espacio de probabilidad.
Un par $(X, Y)$ es un \emph{vector aleatorio discreto} si ambas componentes
toman valores en conjuntos contables.
\end{definicion}
 
\begin{itemize}[leftmargin=1.5cm]
    \item $X \in \{0, 1, 2\}$: defectos visuales por lote.
    \item $Y \in \{0, 1, 2\}$: fallas eléctricas por lote.
\end{itemize}
 
\subsection{Función de Probabilidad Conjunta}
 
La función de masa de probabilidad conjunta (f.m.p.c.) se define como:
\begin{equation}
    f(x,y) = P(X = x,\; Y = y), \qquad (x,y) \in \mathcal{S}
    \label{eq:fmp}
\end{equation}
 
donde el \textbf{soporte} es:
\begin{equation}
    \mathcal{S} = \{0,1,2\} \times \{0,1,2\}
    = \{(0,0),(0,1),(0,2),(1,0),(1,1),(1,2),(2,0),(2,1),(2,2)\}
    \label{eq:soporte}
\end{equation}
 
Los valores concretos son:
 
\begin{equation}
    f(x,y) = \begin{cases}
        0.20 & (x,y)=(0,0) \\
        0.10 & (x,y)=(0,1) \\
        0.05 & (x,y)=(0,2) \\
        0.15 & (x,y)=(1,0) \\
        0.20 & (x,y)=(1,1) \\
        0.05 & (x,y)=(1,2) \\
        0.05 & (x,y)=(2,0) \\
        0.10 & (x,y)=(2,1) \\
        0.10 & (x,y)=(2,2) \\
        0    & \text{en otro caso}
    \end{cases}
    \label{eq:valores}
\end{equation}
 
\subsection{Verificación de la Condición de Normalización}
 
Para que $f(x,y)$ sea una f.m.p. válida, se debe cumplir:
\begin{equation}
    \sum_{x \in \mathcal{S}_X}\sum_{y \in \mathcal{S}_Y} f(x,y) = 1
    \label{eq:normalizacion}
\end{equation}
 
\begin{align*}
    \sum_{x,y} f(x,y)
        &= 0.20 + 0.10 + 0.05
         + 0.15 + 0.20 + 0.05
         + 0.05 + 0.10 + 0.10 \\
        &= 0.35 + 0.40 + 0.25 \\
        &= \boxed{1.00} \quad \checkmark
\end{align*}
 
