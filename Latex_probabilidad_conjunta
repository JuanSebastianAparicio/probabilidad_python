%  3. DESARROLLO
% ============================================================
\section{Desarrollo}
 
\subsection{Probabilidades Específicas}
 
\subsubsection{Probabilidad \texorpdfstring{$P(X + Y \leq 2)$}{P(X+Y<=2)}}
 
Los pares $(x,y)$ con $x + y \leq 2$ son:
$(0,0),(0,1),(0,2),(1,0),(1,1),(2,0)$.
 
\begin{align}
    P(X+Y \leq 2)
        &= f(0,0)+f(0,1)+f(0,2)+f(1,0)+f(1,1)+f(2,0) \notag \\
        &= 0.20 + 0.10 + 0.05 + 0.15 + 0.20 + 0.05 \notag \\
        &= \boxed{0.75}
    \label{eq:p_suma2}
\end{align}
 
\subsubsection{Probabilidad \texorpdfstring{$P(X = Y)$}{P(X=Y)}}
 
\begin{align}
    P(X = Y)
        &= f(0,0) + f(1,1) + f(2,2) \notag \\
        &= 0.20 + 0.20 + 0.10
         = \boxed{0.50}
    \label{eq:p_igual}
\end{align}
 
\subsubsection{Probabilidad \texorpdfstring{$P(X \geq 1,\; Y \geq 1)$}{P(X>=1, Y>=1)}}
 
\begin{align}
    P(X \geq 1,\; Y \geq 1)
        &= f(1,1)+f(1,2)+f(2,1)+f(2,2) \notag \\
        &= 0.20 + 0.05 + 0.10 + 0.10
         = \boxed{0.45}
    \label{eq:p_ambos1}
\end{align}
 
% --------------------------------------------------------
\subsection{Distribuciones Marginales}
% --------------------------------------------------------
 
\subsubsection{Marginal de \texorpdfstring{$X$}{X}}
 
\begin{equation}
    f_X(x) = \sum_{y=0}^{2} f(x,y)
    \label{eq:margX}
\end{equation}
 
\begin{align}
    f_X(0) &= f(0,0)+f(0,1)+f(0,2) = 0.20+0.10+0.05 = \mathbf{0.35} \\
    f_X(1) &= f(1,0)+f(1,1)+f(1,2) = 0.15+0.20+0.05 = \mathbf{0.40} \\
    f_X(2) &= f(2,0)+f(2,1)+f(2,2) = 0.05+0.10+0.10 = \mathbf{0.25}
\end{align}
 
\textbf{Verificación:} $0.35 + 0.40 + 0.25 = 1.00\;\checkmark$
 
\subsubsection{Marginal de \texorpdfstring{$Y$}{Y}}
 
\begin{equation}
    f_Y(y) = \sum_{x=0}^{2} f(x,y)
    \label{eq:margY}
\end{equation}
 
\begin{align}
    f_Y(0) &= f(0,0)+f(1,0)+f(2,0) = 0.20+0.15+0.05 = \mathbf{0.40} \\
    f_Y(1) &= f(0,1)+f(1,1)+f(2,1) = 0.10+0.20+0.10 = \mathbf{0.40} \\
    f_Y(2) &= f(0,2)+f(1,2)+f(2,2) = 0.05+0.05+0.10 = \mathbf{0.20}
\end{align}
 
\textbf{Verificación:} $0.40 + 0.40 + 0.20 = 1.00\;\checkmark$
 
